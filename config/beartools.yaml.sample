# beartools 配置文件示例
# 将此文件复制为 beartools.yaml 并根据需要修改配置

# 日志配置
log:
  # 日志文件路径，默认：log/beartools.log
  path: "log/beartools.log"
  # 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL，默认：INFO
  level: "INFO"
  # 自定义日志配置文件路径（可选），如果指定则使用该配置文件
  # config_file: "config/logging.yaml"

# 健康检查配置
doctor:
  # 启用的检查项列表；默认不包含 siyuan 本地服务检查
  enabled_checks:
    - "google_ping"
    - "opencli"
    - "llm"
  
  # 各检查项的具体配置
  checks:
    # 科学上网 HTTPS 连通性检查配置
    google_ping:
      # 超时时间（秒），默认：2
      timeout: 2
      # 检查失败时是否终止运行，默认：true
      fail_on_error: true
      # 至少 3 个目标返回 HTTPS 响应时视为通过
      success_threshold: 3
      # 并发检测目标列表
      targets:
        - "https://www.google.com/generate_204"
        - "https://www.youtube.com/"
        - "https://www.facebook.com/"
        - "https://www.wikipedia.org/"
        - "https://www.instagram.com/"
        - "https://www.baidu.com/"
    
    # OpenCLI可用性检查配置
    opencli:
      timeout: 3
      fail_on_error: false
    
    # Siyuan思源笔记服务检查配置；需要时可手动加入 enabled_checks
    siyuan:
      # 超时时间（秒），默认：2
      timeout: 2
      # 检查失败时是否终止运行，默认：true
      fail_on_error: false

    # LLM 节点健康检查配置
    llm:
      # 预留字段，当前探测超时仍由 agent 节点各自的 timeout_seconds 控制
      timeout: 2
      # 当前检查固定按失败处理，保留该字段仅为保持配置结构一致
      fail_on_error: true

# 思源笔记配置
siyuan:
  token: "@get siyuan.token"
  default_note: "REPLACE_ME_NOTE_ID"
  notebook: "REPLACE_ME_NOTEBOOK_ID"
  path: "/REPLACE_ME_PATH"

# 智能体节点配置
# 注意：此段为样例配置，字段必须与 src/beartools/config.py 中的 AgentNodeConfig/AgentConfig 完全一致
# 可用字段：name、provider、base_url、model、api_key、extra_headers、timeout_seconds
# 说明：
#   - agent.large / agent.small 都是必填非空列表
#   - large 表示偏大、偏慢的模型池；small 表示偏小、偏快的模型池
#   - provider 仅支持 openai/anthropic
#   - 运行时按列表顺序选择第一个可用节点，对应列表全部不可用则报错
#   - 样例中的 api_key 仅为占位引用，请在生产环境使用 secrets 或环境变量注入真实密钥
agent:
  large:
    - name: "large-1"
      provider: "openai"
      base_url: "https://api.example.com/v1"
      model: "gpt-5"
      api_key: "@get agent.openai.key"
      extra_headers: {}
      timeout_seconds: 30
  small:
    - name: "small-1"
      provider: "openai"
      base_url: "https://api-backup.example.com/v1"
      model: "gpt-4.1-mini"
      api_key: "@get agent.openai.key"
      extra_headers: {}
      timeout_seconds: 30

# Gmail 配置
gmail:
  output_dir: "email"
  default_days: 3
  max_results: 100

# Codex 配置
codex:
  base_url: "https://api-xai.ainaibahub.com/v1"
  api_key: "@get codex.api_key"
  model: "grok-3-mini"
  pic_model: "gpt-image-2"
  instructions: "你是 Codex 助手"
  output_dir: "output/codex"
  timeout_seconds: 60
  pic_size: "1024x1024"
  pic_quality: "high"
  pic_output_format: "png"
  pic_response_format: "b64_json"
  vplan:
    key: "@get codex.vplan.key"
  # bin_path: "/usr/local/bin/codex"
