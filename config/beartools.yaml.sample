# beartools 配置文件示例
# 将此文件复制为 beartools.yaml 并根据需要修改配置

# 日志配置
log:
  # 日志文件路径，默认：log/beartools.log
  path: "log/beartools.log"
  # 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL，默认：INFO
  level: "INFO"
  # 自定义日志配置文件路径（可选），如果指定则使用该配置文件
  # config_file: "config/logging.yaml"

# 健康检查配置
doctor:
  # 启用的检查项列表，默认启用所有检查
  enabled_checks:
    - "google_ping"
    - "opencli"
    - "siyuan"
    - "llm"
  
  # 各检查项的具体配置
  checks:
    # Google网络连通性检查配置
    google_ping:
      # 超时时间（秒），默认：2
      timeout: 2
      # 检查失败时是否终止运行，默认：true
      fail_on_error: true
    
    # OpenCLI可用性检查配置
    opencli:
      timeout: 3
      fail_on_error: false
    
    # Siyuan思源笔记服务检查配置
    siyuan:
      # 超时时间（秒），默认：2
      timeout: 2
      # 检查失败时是否终止运行，默认：true
      fail_on_error: false

    # LLM 节点健康检查配置
    llm:
      # 预留字段，当前探测超时仍由 agent 节点各自的 timeout_seconds 控制
      timeout: 2
      # 当前检查固定按失败处理，保留该字段仅为保持配置结构一致
      fail_on_error: true

# 思源笔记配置
siyuan:
  token: "REPLACE_ME"
  default_note: "REPLACE_ME_NOTE_ID"
  notebook: "REPLACE_ME_NOTEBOOK_ID"
  path: "/REPLACE_ME_PATH"

# 智能体节点配置
agent:
  primary:
    name: "primary"
    provider: "openai"
    base_url: "https://api.example.com/v1"
    model: "gpt-4.1-mini"
    api_key: "REPLACE_ME"
    extra_headers: {}
    timeout_seconds: 30
  candidates:
    - name: "candidate-1"
      provider: "openrouter"
      base_url: "https://api-backup.example.com/v1"
      model: "gpt-4.1-mini"
      api_key: "REPLACE_ME"
      extra_headers: {}
      timeout_seconds: 30
